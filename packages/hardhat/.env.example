# Hardhat vars (set via: npx hardhat vars set <NAME>)
#
# MNEMONIC          — deployer wallet mnemonic (default: hardhat test mnemonic)
# INFURA_API_KEY    — Infura project ID for Sepolia RPC
# ETHERSCAN_API_KEY — Etherscan API key for contract verification
#
# Usage:
#   npx hardhat vars set MNEMONIC "your twelve word mnemonic phrase here"
#   npx hardhat vars set INFURA_API_KEY "your_infura_key"
#   npx hardhat vars set ETHERSCAN_API_KEY "your_etherscan_key"
#
# Deploy:
#   pnpm deploy:sepolia
