# Hardhat vars (set via: npx hardhat vars set <NAME>)
#
# DEPLOYER_PK       — deployer wallet private key (with 0x prefix)
# ALCHEMY_API_KEY   — Alchemy API key for Sepolia RPC
# ETHERSCAN_API_KEY  — Etherscan API key for contract verification
#
# Usage:
#   npx hardhat vars set DEPLOYER_PK "0x..."
#   npx hardhat vars set ALCHEMY_API_KEY "your_alchemy_key"
#   npx hardhat vars set ETHERSCAN_API_KEY "your_etherscan_key"
#
# Deploy:
#   pnpm deploy:sepolia
#
# Generate frontend ABIs:
#   npx ts-node scripts/generateDeployedContracts.ts sepolia
